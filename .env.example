# LLM Provider — uses HuggingFace Inference API for LLM + embeddings
LLM_PROVIDER=huggingface
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_MODEL_ID=openai/gpt-oss-20b

# Embedding model (HF Inference API). Must match VECTOR_SIZE in ingest.py (384 for MiniLM-L12-v2).
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Qdrant Cloud — vector database
QDRANT_URL=https://your-cluster.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_TECHNICAL=kb_technical
QDRANT_COLLECTION_HR=kb_hr

# Langfuse (optional observability — leave blank to disable tracing)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
